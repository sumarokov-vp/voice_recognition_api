WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=ru
WHISPER_MODEL_DIR=/models

API_HOST=0.0.0.0
API_PORT=8000

MAX_FILE_SIZE_MB=1000

# UID/GID хоста для bind-mount ./data/models (чтобы файлы моделей принадлежали текущему пользователю)
HOST_UID=1000
HOST_GID=1000
